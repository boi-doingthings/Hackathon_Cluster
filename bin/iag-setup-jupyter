#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/iag-common
source "$SCRIPT_DIR/iag-common"

usage() {
    cat <<'EOF'
Usage: iag-setup-jupyter [--workspace PATH]

Prepare the per-user JupyterLab virtual environment in team storage.
Run this on the login node if first-time package installation is slow from a GPU job.
EOF
}

workspace=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --workspace) workspace="${2:-}"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) iag_die "unknown option: $1" ;;
    esac
done

if [[ -n "$workspace" ]]; then
    [[ -d "$workspace" && -w "$workspace" && -x "$workspace" ]] || iag_die "workspace is not writable: $workspace"
    workdir="$workspace"
else
    workdir="$(iag_require_workspace_dir)"
fi

runtime_dir="$(iag_runtime_dir "$workdir")"
venv_dir="${runtime_dir}/venvs/${IAG_JUPYTER_VENV_NAME}"

mkdir -p \
    "${runtime_dir}/venvs" \
    "${runtime_dir}/cache/uv" \
    "${runtime_dir}/cache/pip" \
    "${runtime_dir}/tmp"

export UV_CACHE_DIR="${runtime_dir}/cache/uv"
export PIP_CACHE_DIR="${runtime_dir}/cache/pip"
export TMPDIR="${runtime_dir}/tmp"
export UV_HTTP_TIMEOUT="${IAG_UV_HTTP_TIMEOUT}"
export PIP_DEFAULT_TIMEOUT="${IAG_PIP_DEFAULT_TIMEOUT}"
export UV_LINK_MODE="${IAG_UV_LINK_MODE}"

if ! command -v uv >/dev/null 2>&1 && command -v module >/dev/null 2>&1; then
    module load "${IAG_UV_MODULE}" >/dev/null 2>&1 || module load uv >/dev/null 2>&1 || true
fi

echo "Preparing JupyterLab environment"
echo "Workspace: $workdir"
echo "Jupyter venv: $venv_dir"
echo "Package timeout: ${IAG_UV_HTTP_TIMEOUT}s"
echo "UV cache: ${UV_CACHE_DIR}"
echo "UV link mode: ${UV_LINK_MODE}"
echo

if [[ ! -d "$venv_dir" ]]; then
    if command -v uv >/dev/null 2>&1; then
        echo "Creating venv with $(uv --version)"
        uv venv "$venv_dir"
    else
        echo "Creating venv with $(python3 --version)"
        python3 -m venv "$venv_dir"
    fi
fi

source "${venv_dir}/bin/activate"

if command -v jupyter >/dev/null 2>&1; then
    echo "JupyterLab is already available:"
    jupyter lab --version
    exit 0
fi

echo "Installing JupyterLab..."
if command -v uv >/dev/null 2>&1; then
    echo "Using $(uv --version)"
    uv pip install jupyterlab
else
    echo "Using $(python --version) with pip"
    python -m ensurepip --upgrade >/dev/null 2>&1 || true
    python -m pip install jupyterlab
fi

echo
echo "JupyterLab is ready:"
jupyter lab --version
