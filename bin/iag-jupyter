#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/iag-common
source "$SCRIPT_DIR/iag-common"

usage() {
    cat <<'EOF'
Usage: iag-jupyter [--gpus 1|2|3|4] [--time HH:MM:SS] [--partition NAME] [--cpus N] [--mem SIZE] [--port PORT] [--workspace PATH]

Submit a Slurm job that creates/uses a JupyterLab virtualenv on a GPU compute node.
Rootless Docker is started automatically.
Memory is not requested by default; pass --mem only if you need a specific amount.
EOF
}

gpus=1
time_limit="$IAG_DEFAULT_TIME"
partition="$IAG_DEFAULT_PARTITION"
cpus="$IAG_DEFAULT_CPUS"
mem="$IAG_DEFAULT_MEM"
external_port="$IAG_JUPYTER_EXTERNAL_PORT"
workspace=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --gpus) gpus="${2:-}"; shift 2 ;;
        --time) time_limit="${2:-}"; shift 2 ;;
        --partition) partition="${2:-}"; shift 2 ;;
        --cpus) cpus="${2:-}"; shift 2 ;;
        --mem) mem="${2:-}"; shift 2 ;;
        --port) external_port="${2:-}"; shift 2 ;;
        --workspace) workspace="${2:-}"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) iag_die "unknown option: $1" ;;
    esac
done

iag_validate_gpus "$gpus"
iag_need_cmd sbatch

if [[ -n "$workspace" ]]; then
    [[ -d "$workspace" && -w "$workspace" && -x "$workspace" ]] || iag_die "workspace is not writable: $workspace"
    workdir="$workspace"
else
    workdir="$(iag_require_workspace_dir)"
fi
runtime_dir="$(iag_runtime_dir "$workdir")"
logs_dir="${runtime_dir}/logs"
mkdir -p "$logs_dir"
output_file="${logs_dir}/jupyter-%j.out"

args=(
    --parsable
    --job-name "iag-jupyter"
    --partition "$partition"
    --gres "gpu:${gpus}"
    --cpus-per-task "$cpus"
    --time "$time_limit"
    --chdir "$workdir"
    --output "$output_file"
    --export "ALL,IAG_JUPYTER_EXTERNAL_PORT=${external_port},IAG_LOGIN_HOST=${IAG_LOGIN_HOST},IAG_JUPYTER_VENV_NAME=${IAG_JUPYTER_VENV_NAME},IAG_RUNTIME_DIR=${runtime_dir}"
)

if [[ -n "$mem" ]]; then
    args+=(--mem "$mem")
fi

jobid="$(
    sbatch "${args[@]}" <<'SBATCH'
#!/bin/bash -l
set -euo pipefail
umask 0007

EXTERNAL_PORT="${IAG_JUPYTER_EXTERNAL_PORT:-8001}"
LOGIN_HOST="${IAG_LOGIN_HOST:-ssh.axisapps.io}"
VENV_NAME="${IAG_JUPYTER_VENV_NAME:-iag-jupyter}"
RUNTIME_DIR="${IAG_RUNTIME_DIR:-${PWD}/.iag/${USER:-user}}"
NODE="$(hostname -f 2>/dev/null || hostname)"
mkdir -p \
    "${RUNTIME_DIR}/venvs" \
    "${RUNTIME_DIR}/jupyter/config" \
    "${RUNTIME_DIR}/jupyter/data" \
    "${RUNTIME_DIR}/jupyter/runtime" \
    "${RUNTIME_DIR}/ipython" \
    "${RUNTIME_DIR}/cache/uv" \
    "${RUNTIME_DIR}/cache/pip"
chmod -R g+rwX "${RUNTIME_DIR}" 2>/dev/null || true

export JUPYTER_CONFIG_DIR="${RUNTIME_DIR}/jupyter/config"
export JUPYTER_DATA_DIR="${RUNTIME_DIR}/jupyter/data"
export JUPYTER_RUNTIME_DIR="${RUNTIME_DIR}/jupyter/runtime"
export IPYTHONDIR="${RUNTIME_DIR}/ipython"
export UV_CACHE_DIR="${RUNTIME_DIR}/cache/uv"
export PIP_CACHE_DIR="${RUNTIME_DIR}/cache/pip"

while true; do
    PORT="$(shuf -n 1 -i 9000-9999)"
    if command -v ss >/dev/null 2>&1; then
        ss -ltn | awk '{print $4}' | grep -q ":${PORT}$" || break
    elif command -v netstat >/dev/null 2>&1; then
        netstat -atun | grep -q ":${PORT}" || break
    else
        break
    fi
done

echo "Jupyter job started"
echo "Node: ${NODE}"
echo "Internal Jupyter port: ${PORT}"
echo "Local browser port: ${EXTERNAL_PORT}"
echo "Workspace: ${PWD}"
echo "GPUs visible:"
nvidia-smi -L || true
echo

echo "Loading rootless Docker..."
module load rootless-docker
if command -v start_rootless_docker >/dev/null 2>&1; then
    start_rootless_docker
else
    start_rootless_docker.sh
fi
docker version --format "Docker Client: {{.Client.Version}} Server: {{.Server.Version}}" || docker version
echo

echo "Preparing Jupyter virtual environment..."
module load uv
VENV_DIR="${RUNTIME_DIR}/venvs/${VENV_NAME}"
if [[ ! -d "${VENV_DIR}" ]]; then
    uv venv "${VENV_DIR}"
fi
source "${VENV_DIR}/bin/activate"
if ! command -v jupyter >/dev/null 2>&1; then
    uv pip install --upgrade pip
    uv pip install jupyterlab
fi
echo "Jupyter venv: ${VENV_DIR}"
echo

HASHNUMBER="${UNIQUE_AXIS_HASH:-${USER:-<UNIQUE_AXIS_HASH>}}"
TUNNEL_FILE="${RUNTIME_DIR}/port_forwarding_command.jupyter"
echo "From your laptop, run:"
echo "ssh -L localhost:${EXTERNAL_PORT}:${NODE}:${PORT} ${LOGIN_HOST} -l ${HASHNUMBER}"
echo
echo "Then open:"
echo "http://localhost:${EXTERNAL_PORT}"
echo
echo "ssh -L localhost:${EXTERNAL_PORT}:${NODE}:${PORT} ${LOGIN_HOST} -l ${HASHNUMBER}" > "${TUNNEL_FILE}"
echo "Port forwarding command was also written to: ${TUNNEL_FILE}"
echo

exec jupyter lab \
    --no-browser \
    --allow-root \
    --ip=0.0.0.0 \
    --port="${PORT}" \
    --ServerApp.token="" \
    --NotebookApp.token="" \
    --notebook-dir="${PWD}"
SBATCH
)"

resolved_output="${output_file//%j/$jobid}"

echo "Submitted Jupyter job: $jobid"
echo "Log file: $resolved_output"
echo
echo "Watch startup logs with:"
echo "tail -f $resolved_output"
echo
echo "Once the job starts, the log will show the SSH tunnel command and browser URL."
