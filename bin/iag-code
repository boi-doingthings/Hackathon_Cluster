#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/iag-common
source "$SCRIPT_DIR/iag-common"

usage() {
    cat <<'EOF'
Usage: iag-code [--gpus 1|2|3|4] [--time HH:MM:SS] [--partition NAME] [--cpus N] [--mem SIZE] [--port PORT]

Submit a Slurm job that starts code-server on a GPU compute node.
The editor opens in the team fast-storage directory. Rootless Docker is started automatically.
Memory is not requested by default; pass --mem only if you need a specific amount.
EOF
}

gpus=1
time_limit="$IAG_DEFAULT_TIME"
partition="$IAG_DEFAULT_PARTITION"
cpus="$IAG_DEFAULT_CPUS"
mem="$IAG_DEFAULT_MEM"
external_port="$IAG_CODE_EXTERNAL_PORT"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --gpus) gpus="${2:-}"; shift 2 ;;
        --time) time_limit="${2:-}"; shift 2 ;;
        --partition) partition="${2:-}"; shift 2 ;;
        --cpus) cpus="${2:-}"; shift 2 ;;
        --mem) mem="${2:-}"; shift 2 ;;
        --port) external_port="${2:-}"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) iag_die "unknown option: $1" ;;
    esac
done

iag_validate_gpus "$gpus"
iag_need_cmd sbatch

workdir="$(iag_workspace_dir)"
runtime_dir="$(iag_runtime_dir "$workdir")"
logs_dir="$(iag_logs_dir)"
output_file="${logs_dir}/code-%j.out"

args=(
    --parsable
    --job-name "iag-code"
    --partition "$partition"
    --gres "gpu:${gpus}"
    --cpus-per-task "$cpus"
    --time "$time_limit"
    --chdir "$workdir"
    --output "$output_file"
    --export "ALL,IAG_CODE_EXTERNAL_PORT=${external_port},IAG_LOGIN_HOST=${IAG_LOGIN_HOST},IAG_RUNTIME_DIR=${runtime_dir}"
)

if [[ -n "$mem" ]]; then
    args+=(--mem "$mem")
fi

jobid="$(
    sbatch "${args[@]}" <<'SBATCH'
#!/bin/bash -l
set -euo pipefail
umask 0007

EXTERNAL_PORT="${IAG_CODE_EXTERNAL_PORT:-8080}"
LOGIN_HOST="${IAG_LOGIN_HOST:-ssh.axisapps.io}"
RUNTIME_DIR="${IAG_RUNTIME_DIR:-${PWD}/.iag/${USER:-user}}"
NODE="$(hostname -f 2>/dev/null || hostname)"
mkdir -p \
    "${RUNTIME_DIR}/code-server/config" \
    "${RUNTIME_DIR}/code-server/data" \
    "${RUNTIME_DIR}/code-server/extensions" \
    "${RUNTIME_DIR}/cache"
chmod -R g+rwX "${RUNTIME_DIR}" 2>/dev/null || true

export XDG_CONFIG_HOME="${RUNTIME_DIR}/code-server/config"
export XDG_DATA_HOME="${RUNTIME_DIR}/code-server/data"
export XDG_CACHE_HOME="${RUNTIME_DIR}/cache"

while true; do
    PORT="$(shuf -n 1 -i 10000-10999)"
    if command -v ss >/dev/null 2>&1; then
        ss -ltn | awk '{print $4}' | grep -q ":${PORT}$" || break
    elif command -v netstat >/dev/null 2>&1; then
        netstat -atun | grep -q ":${PORT}" || break
    else
        break
    fi
done

echo "VS Code job started"
echo "Node: ${NODE}"
echo "Internal code-server port: ${PORT}"
echo "Local browser port: ${EXTERNAL_PORT}"
echo "Workspace: ${PWD}"
echo "GPUs visible:"
nvidia-smi -L || true
echo

echo "Loading rootless Docker..."
module load rootless-docker
if command -v start_rootless_docker >/dev/null 2>&1; then
    start_rootless_docker
else
    start_rootless_docker.sh
fi
docker version --format "Docker Client: {{.Client.Version}} Server: {{.Server.Version}}" || docker version
echo

if ! command -v code-server >/dev/null 2>&1; then
    echo "code-server is not available in this environment." >&2
    echo "Ask the support team to install code-server as a module or put it on PATH." >&2
    exit 127
fi

HASHNUMBER="${UNIQUE_AXIS_HASH:-${USER:-<UNIQUE_AXIS_HASH>}}"
TUNNEL_FILE="${RUNTIME_DIR}/port_forwarding_command.code"
echo "From your laptop, run:"
echo "ssh -L localhost:${EXTERNAL_PORT}:${NODE}:${PORT} ${LOGIN_HOST} -l ${HASHNUMBER}"
echo
echo "Then open:"
echo "http://localhost:${EXTERNAL_PORT}"
echo
echo "ssh -L localhost:${EXTERNAL_PORT}:${NODE}:${PORT} ${LOGIN_HOST} -l ${HASHNUMBER}" > "${TUNNEL_FILE}"
echo "Port forwarding command was also written to: ${TUNNEL_FILE}"
echo

export PASSWORD="${IAG_CODE_PASSWORD:-}"
exec code-server \
    --bind-addr "0.0.0.0:${PORT}" \
    --auth none \
    --disable-telemetry \
    --user-data-dir "${RUNTIME_DIR}/code-server/data" \
    --extensions-dir "${RUNTIME_DIR}/code-server/extensions" \
    "${PWD}"
SBATCH
)"

resolved_output="${output_file//%j/$jobid}"

echo "Submitted VS Code job: $jobid"
echo "Log file: $resolved_output"
echo
echo "Watch startup logs with:"
echo "tail -f $resolved_output"
echo
echo "Once the job starts, the log will show the SSH tunnel command and browser URL."
