#!/usr/bin/env bash

set -euo pipefail

IAG_DEFAULT_PARTITION="${IAG_PARTITION:-primary}"
IAG_DEFAULT_TIME="${IAG_TIME:-04:00:00}"
IAG_DEFAULT_CPUS="${IAG_CPUS:-16}"
IAG_DEFAULT_MEM="${IAG_MEM:-}"
IAG_TEAM_ROOT="${IAG_TEAM_ROOT:-/lustre/fs01/hackathons/teams}"
IAG_LOGIN_HOST="${IAG_LOGIN_HOST:-ssh.axisapps.io}"
IAG_JUPYTER_EXTERNAL_PORT="${IAG_JUPYTER_EXTERNAL_PORT:-8001}"
IAG_JUPYTER_VENV_NAME="${IAG_JUPYTER_VENV_NAME:-iag-jupyter}"
IAG_CODE_EXTERNAL_PORT="${IAG_CODE_EXTERNAL_PORT:-8080}"

iag_die() {
    echo "error: $*" >&2
    exit 1
}

iag_need_cmd() {
    command -v "$1" >/dev/null 2>&1 || iag_die "missing required command: $1"
}

iag_detect_team() {
    if [[ -n "${IAG_TEAM:-}" ]]; then
        echo "$IAG_TEAM"
        return 0
    fi

    id -Gn 2>/dev/null | tr ' ' '\n' | grep -E '^iag-team[0-9]+$' | head -n 1 || true
}

iag_team_scratch() {
    local team="${1:-}"

    if [[ -n "${TEAM_SCRATCH:-}" ]]; then
        echo "$TEAM_SCRATCH"
        return 0
    fi

    [[ -n "$team" ]] || return 1
    echo "${IAG_TEAM_ROOT}/${team}"
}

iag_detect_writable_team_scratch() {
    local matches=()
    local candidate

    [[ -d "$IAG_TEAM_ROOT" ]] || return 1

    for candidate in "$IAG_TEAM_ROOT"/iag-team*; do
        [[ -d "$candidate" && -w "$candidate" && -x "$candidate" ]] || continue
        matches+=("$candidate")
    done

    if [[ "${#matches[@]}" -eq 1 ]]; then
        echo "${matches[0]}"
        return 0
    fi

    return 1
}

iag_workspace_dir() {
    local team
    local scratch

    if [[ -n "${TEAM_SCRATCH:-}" ]]; then
        scratch="$TEAM_SCRATCH"
    else
        team="$(iag_detect_team)"
        if [[ -n "$team" ]]; then
            scratch="${IAG_TEAM_ROOT}/${team}"
        else
            iag_detect_writable_team_scratch
            return $?
        fi
    fi

    if [[ -d "$scratch" && -w "$scratch" && -x "$scratch" ]]; then
        echo "$scratch"
        return 0
    fi

    return 1
}

iag_workspace_diagnostics() {
    local team
    local scratch
    local candidate
    local count=0

    team="$(iag_detect_team)"
    scratch="$(iag_team_scratch "$team" || true)"

    echo "Workspace diagnostics:" >&2
    echo "  USER=${USER:-unknown}" >&2
    echo "  IAG_TEAM=${IAG_TEAM:-not set}" >&2
    echo "  detected team group=${team:-not detected}" >&2
    echo "  TEAM_SCRATCH=${TEAM_SCRATCH:-not set}" >&2
    echo "  candidate path=${scratch:-not available}" >&2

    if [[ -n "$scratch" ]]; then
        if [[ -e "$scratch" ]]; then
            echo "  exists=yes" >&2
            [[ -d "$scratch" ]] && echo "  is_directory=yes" >&2 || echo "  is_directory=no" >&2
            [[ -x "$scratch" ]] && echo "  searchable=yes" >&2 || echo "  searchable=no" >&2
            [[ -w "$scratch" ]] && echo "  writable=yes" >&2 || echo "  writable=no" >&2
            if mkdir -p "${scratch}/.iag-permission-test-${USER:-user}-$$" 2>/dev/null; then
                echo "  can_create_directory=yes" >&2
                rmdir "${scratch}/.iag-permission-test-${USER:-user}-$$" 2>/dev/null || true
            else
                echo "  can_create_directory=no" >&2
            fi
            ls -ld "$scratch" >&2 || true
        else
            echo "  exists=no" >&2
        fi
    fi

    if [[ -d "$IAG_TEAM_ROOT" ]]; then
        echo "  writable team directories visible to this account:" >&2
        for candidate in "$IAG_TEAM_ROOT"/iag-team*; do
            [[ -d "$candidate" && -w "$candidate" && -x "$candidate" ]] || continue
            echo "    $candidate" >&2
            count=$((count + 1))
        done
        [[ "$count" -gt 0 ]] || echo "    none" >&2
    else
        echo "  team root does not exist or is not visible: $IAG_TEAM_ROOT" >&2
    fi
}

iag_validate_gpus() {
    local gpus="$1"
    case "$gpus" in
        1|2|3|4) ;;
        *) iag_die "--gpus must be one of: 1, 2, 3, 4" ;;
    esac
}

iag_context() {
    local team
    local scratch

    team="$(iag_detect_team)"
    scratch="$(iag_team_scratch "$team" || true)"

    echo "User: ${USER:-unknown}"
    echo "Team: ${team:-not detected; set IAG_TEAM=iag-team<N>}"
    echo "Team storage: ${scratch:-not detected; set TEAM_SCRATCH=/lustre/fs01/hackathons/teams/iag-team<N>}"
}

iag_require_workspace_dir() {
    local workspace

    workspace="$(iag_workspace_dir || true)"
    if [[ -n "$workspace" && -d "$workspace" && -w "$workspace" && -x "$workspace" ]]; then
        echo "$workspace"
        return 0
    fi

    cat >&2 <<'EOF'
error: could not detect a writable team fast-storage directory.

Set it explicitly, then rerun the command:

  export TEAM_SCRATCH=/lustre/fs01/hackathons/teams/iag-team<N>

If you know your team number, you may also set:

  export IAG_TEAM=iag-team<N>
EOF
    echo >&2
    iag_workspace_diagnostics
    exit 1
}

iag_runtime_dir() {
    local workspace="$1"
    local state_root
    local runtime_dir

    state_root="${workspace}/.iag"
    runtime_dir="${state_root}/${USER:-user}"

    if ! mkdir -p "$runtime_dir"; then
        cat >&2 <<EOF
error: could not create per-user runtime directory:

  ${runtime_dir}

The team storage path is visible, but this account cannot create directories there.
Ask the cluster admin to make the team directory group-writable for the iag-team group.
EOF
        echo >&2
        iag_workspace_diagnostics
        return 1
    fi

    chmod 2770 "$state_root" 2>/dev/null || true
    chmod 2770 "$runtime_dir" 2>/dev/null || true
    echo "$runtime_dir"
}

iag_logs_dir() {
    local workspace
    local runtime_dir

    workspace="$(iag_workspace_dir || true)"

    if [[ -n "$workspace" && -d "$workspace" && -w "$workspace" ]]; then
        runtime_dir="$(iag_runtime_dir "$workspace")" || return 1
        mkdir -p "$runtime_dir/logs" || return 1
        chmod 2770 "$runtime_dir/logs" 2>/dev/null || true
        echo "$runtime_dir/logs"
    else
        mkdir -p "$PWD/logs"
        echo "$PWD/logs"
    fi
}
