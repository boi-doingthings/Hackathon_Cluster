#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/iag-common
source "$SCRIPT_DIR/iag-common"

usage() {
    cat <<'EOF'
Usage: iag-shell [--gpus 1|2|3|4] [--time HH:MM:SS] [--partition NAME] [--cpus N] [--mem SIZE] [--workspace PATH]

Start an interactive shell on a Slurm compute node. Docker is checked automatically.
Memory is not requested by default; pass --mem only if you need a specific amount.
EOF
}

gpus=1
time_limit="$IAG_DEFAULT_TIME"
partition="$IAG_DEFAULT_PARTITION"
cpus="$IAG_DEFAULT_CPUS"
mem="$IAG_DEFAULT_MEM"
workspace=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --gpus) gpus="${2:-}"; shift 2 ;;
        --time) time_limit="${2:-}"; shift 2 ;;
        --partition) partition="${2:-}"; shift 2 ;;
        --cpus) cpus="${2:-}"; shift 2 ;;
        --mem) mem="${2:-}"; shift 2 ;;
        --workspace) workspace="${2:-}"; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) iag_die "unknown option: $1" ;;
    esac
done

iag_validate_gpus "$gpus"
iag_need_cmd srun
if [[ -n "$workspace" ]]; then
    [[ -d "$workspace" && -w "$workspace" && -x "$workspace" ]] || iag_die "workspace is not writable: $workspace"
    workdir="$workspace"
else
    workdir="$(iag_require_workspace_dir)"
fi
runtime_dir="$(iag_runtime_dir "$workdir")"
mkdir -p "${runtime_dir}/cache/uv" "${runtime_dir}/cache/pip" "${runtime_dir}/tmp"

export UV_CACHE_DIR="${runtime_dir}/cache/uv"
export PIP_CACHE_DIR="${runtime_dir}/cache/pip"
export TMPDIR="${runtime_dir}/tmp"
export UV_HTTP_TIMEOUT="${IAG_UV_HTTP_TIMEOUT}"
export PIP_DEFAULT_TIMEOUT="${IAG_PIP_DEFAULT_TIMEOUT}"
export UV_LINK_MODE="${IAG_UV_LINK_MODE}"
export IAG_UV_MODULE

echo "Requesting interactive Slurm shell..."
echo "GPUs: $gpus"
echo "CPUs: $cpus"
echo "Memory: ${mem:-cluster default}"
echo "Time: $time_limit"
echo "Partition: $partition"
echo
iag_context
echo "Start directory: $workdir"
echo

args=(
    --partition "$partition"
    --gres "gpu:${gpus}"
    --cpus-per-task "$cpus"
    --time "$time_limit"
    --chdir "$workdir"
)

if [[ -n "$mem" ]]; then
    args+=(--mem "$mem")
fi

exec srun "${args[@]}" \
    --pty bash -lc '
        set -euo pipefail
        umask 0007
        echo "Compute node: $(hostname -f 2>/dev/null || hostname)"
        echo "Working directory: $PWD"
        echo "Checking Docker daemon..."
        docker info >/dev/null
        echo "Docker is ready:"
        docker version --format "Client: {{.Client.Version}} Server: {{.Server.Version}}" || docker version
        if ! command -v uv >/dev/null 2>&1 && command -v module >/dev/null 2>&1; then
            module load "${IAG_UV_MODULE}" >/dev/null 2>&1 || module load uv >/dev/null 2>&1 || true
        fi
        echo "Python package cache: ${UV_CACHE_DIR}"
        echo "UV link mode: ${UV_LINK_MODE}"
        echo
        exec bash -l
    '
